<Window x:Class="AudioVisualizer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:AudioVisualizer"
        mc:Ignorable="d"
        Title="AudioVisualizer" Height="150" Width="400"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        Topmost="True" ResizeMode="NoResize">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </Window.Resources>

    <Border Background="#B3000000" CornerRadius="12" BorderBrush="#33FFFFFF" BorderThickness="1" Margin="5">
        <Border.ContextMenu>
            <ContextMenu>
                <MenuItem Header="Settings">
                    <MenuItem Header="Show Scrolling Text" IsCheckable="True" IsChecked="{Binding IsScrollingTextVisible}"/>
                    <MenuItem Header="Show Peak Indicators" IsCheckable="True" IsChecked="{Binding IsPeakHoldEnabled}"/>
                    <Separator/>
                    <MenuItem Header="Text Style">
                        <MenuItem Header="Modern" IsCheckable="True" IsChecked="{Binding IsModernStyle}"/>
                        <MenuItem Header="Digital" IsCheckable="True" IsChecked="{Binding IsDigitalStyle}"/>
                    </MenuItem>
                    <MenuItem Header="Text Color">
                        <MenuItem Header="White" IsCheckable="True" IsChecked="{Binding IsWhiteColor}"/>
                        <MenuItem Header="Red" IsCheckable="True" IsChecked="{Binding IsRedColor}"/>
                        <MenuItem Header="Blue" IsCheckable="True" IsChecked="{Binding IsBlueColor}"/>
                        <MenuItem Header="Green" IsCheckable="True" IsChecked="{Binding IsGreenColor}"/>
                        <MenuItem Header="Yellow" IsCheckable="True" IsChecked="{Binding IsYellowColor}"/>
                        <MenuItem Header="Magenta" IsCheckable="True" IsChecked="{Binding IsMagentaColor}"/>
                        <MenuItem Header="Cyan" IsCheckable="True" IsChecked="{Binding IsCyanColor}"/>
                    </MenuItem>
                    <MenuItem Header="Visualizer Style">
                        <MenuItem Header="Gradient (Default)" IsCheckable="True" IsChecked="{Binding IsGradientStyle}"/>
                        <MenuItem Header="Classic (Winamp)" IsCheckable="True" IsChecked="{Binding IsClassicStyle}"/>
                    </MenuItem>
                    <Separator/>
                    <MenuItem Header="About">
                        <MenuItem Header="Lasse Nurmela 2026" IsEnabled="False"/>
                        <MenuItem Header="Coffee tips btc: bc1qnz53ne04hvx6e5cyn7g4zxnsyegpquscm7pxm4" Click="CopyBtc_Click" ToolTip="Click to Copy"/>
                    </MenuItem>
                </MenuItem>
                <Separator/>
                <MenuItem Header="Exit" Click="Exit_Click"/>
            </ContextMenu>
        </Border.ContextMenu>

        <Border.Effect>
            <DropShadowEffect Color="Black" BlurRadius="20" ShadowDepth="5" Opacity="0.5"/>
        </Border.Effect>

        <!-- Reduced Bottom Margin -->
        <Grid Margin="10,10,10,5">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Spectrum Visualizer -->
            <ItemsControl ItemsSource="{Binding SpectrumData}" Grid.Row="0" VerticalAlignment="Bottom" Height="120" Margin="10,0,10,5">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <UniformGrid Rows="1"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Grid VerticalAlignment="Bottom" Height="120" Margin="1,0">
                            <!-- The Bar -->
                            <Rectangle VerticalAlignment="Bottom" RadiusX="1" RadiusY="1">
                                <Rectangle.Fill>
                                    <Binding Path="DataContext.BarBrush" RelativeSource="{RelativeSource AncestorType=Window}"/>
                                </Rectangle.Fill>
                                <Rectangle.LayoutTransform>
                                    <ScaleTransform ScaleY="{Binding Value}"/>
                                </Rectangle.LayoutTransform>
                                <Rectangle.Height>120</Rectangle.Height>
                            </Rectangle>

                            <!-- The Peak Indicator -->
                            <Rectangle Height="2" HorizontalAlignment="Stretch" VerticalAlignment="Bottom" Fill="White" Opacity="0.8"
                                       Visibility="{Binding DataContext.IsPeakHoldEnabled, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource BoolToVis}}">
                                <Rectangle.RenderTransform>
                                    <TranslateTransform Y="{Binding PeakY}"/>
                                </Rectangle.RenderTransform>
                            </Rectangle>
                        </Grid>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- Now Playing Marquee -->
            <!-- Reduced grid height, closer to bottom -->
            <Grid Grid.Row="1" ClipToBounds="True" Height="20" VerticalAlignment="Bottom" Margin="0,0,0,0" Visibility="{Binding IsScrollingTextVisible, Converter={StaticResource BoolToVis}}">
                <Canvas>
                    <!-- Modern Font Style: Segoe UI, SemiBold, Uppercase, Spaced -->
                    <TextBlock x:Name="ScrollingText" 
                               Text="{Binding CurrentTrackName}"
                               Foreground="{Binding CurrentBrush}"
                               FontFamily="{Binding CurrentFontFamily}"
                               FontSize="14">

                        <TextBlock.CacheMode>
                            <BitmapCache EnableClearType="False" RenderAtScale="1" SnapsToDevicePixels="True"/>
                        </TextBlock.CacheMode>
                        <TextBlock.Effect>
                            <DropShadowEffect Color="{Binding CurrentShadowColor}"
                                              BlurRadius="{Binding CurrentBlur}"
                                              ShadowDepth="{Binding CurrentShadowDepth}"
                                              Opacity="0.9"/>
                        </TextBlock.Effect>

                        <TextBlock.RenderTransform>
                            <TranslateTransform x:Name="MarqueeTransform" X="400"/>
                        </TextBlock.RenderTransform>
                    </TextBlock>
                </Canvas>
            </Grid>
        </Grid>
    </Border>
</Window>
