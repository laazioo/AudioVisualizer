<Window x:Class="AudioVisualizer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:AudioVisualizer"
        mc:Ignorable="d"
        Title="AudioVisualizer" Width="400" SizeToContent="Height"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        Topmost="True" ResizeMode="NoResize"
        UseLayoutRounding="True" SnapsToDevicePixels="True">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <local:InvertDoubleConverter x:Key="InvertDoubleConverter"/>
    </Window.Resources>

    <StackPanel>
    <Border Background="#B3000000" CornerRadius="12" BorderBrush="#33FFFFFF" BorderThickness="1" Margin="5">
        <Border.ContextMenu>
            <ContextMenu>
                <MenuItem Header="Settings">
                    <MenuItem Header="Show Scrolling Text" IsCheckable="True" IsChecked="{Binding IsScrollingTextVisible}"/>
                    <MenuItem Header="Show Peak Indicators" IsCheckable="True" IsChecked="{Binding IsPeakHoldEnabled}"/>
                    <MenuItem Header="Show Album Art" IsCheckable="True" IsChecked="{Binding IsAlbumArtVisible}"/>
                    <Separator/>
                    <MenuItem Header="Text Style">
                        <MenuItem Header="Modern" IsCheckable="True" IsChecked="{Binding IsModernStyle}"/>
                        <MenuItem Header="Digital" IsCheckable="True" IsChecked="{Binding IsDigitalStyle}"/>
                    </MenuItem>
                    <MenuItem Header="Text Color">
                        <MenuItem Header="White" IsCheckable="True" IsChecked="{Binding IsWhiteColor}"/>
                        <MenuItem Header="Red" IsCheckable="True" IsChecked="{Binding IsRedColor}"/>
                        <MenuItem Header="Blue" IsCheckable="True" IsChecked="{Binding IsBlueColor}"/>
                        <MenuItem Header="Green" IsCheckable="True" IsChecked="{Binding IsGreenColor}"/>
                        <MenuItem Header="Yellow" IsCheckable="True" IsChecked="{Binding IsYellowColor}"/>
                        <MenuItem Header="Magenta" IsCheckable="True" IsChecked="{Binding IsMagentaColor}"/>
                        <MenuItem Header="Cyan" IsCheckable="True" IsChecked="{Binding IsCyanColor}"/>
                    </MenuItem>
                    <MenuItem Header="Visualizer Shape">
                        <MenuItem Header="Bars (Default)" IsCheckable="True" IsChecked="{Binding IsBarsMode}"/>
                        <MenuItem Header="Oscilloscope (Line)" IsCheckable="True" IsChecked="{Binding IsOscilloscopeMode}"/>
                        <MenuItem Header="Eddie (Heavy Metal)" IsCheckable="True" IsChecked="{Binding IsEddieMode}"/>
                    </MenuItem>
                    <MenuItem Header="Visualizer Color Theme">
                        <MenuItem Header="Gradient (Default)" IsCheckable="True" IsChecked="{Binding IsGradientStyle}"/>
                        <MenuItem Header="Classic (Winamp)" IsCheckable="True" IsChecked="{Binding IsClassicStyle}"/>
                    </MenuItem>
                    <Separator/>
                    <MenuItem Header="About">
                        <MenuItem Header="Lasse Nurmela 2026" IsEnabled="False"/>
                        <MenuItem Header="Coffee tips btc: bc1qnz53ne04hvx6e5cyn7g4zxnsyegpquscm7pxm4" Click="CopyBtc_Click" ToolTip="Click to Copy"/>
                    </MenuItem>
                </MenuItem>
                <Separator/>
                <MenuItem Header="Exit" Click="Exit_Click"/>
            </ContextMenu>
        </Border.ContextMenu>

        <Border.Effect>
            <DropShadowEffect Color="Black" BlurRadius="20" ShadowDepth="5" Opacity="0.5"/>
        </Border.Effect>

        <!-- Reduced Bottom Margin -->
        <Grid Margin="10,10,10,5">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/> <!-- Media Controls Row -->
                <RowDefinition Height="Auto"/> <!-- Eddie Row -->
                <RowDefinition Height="*"/>    <!-- Main Visualizer Row -->
                <RowDefinition Height="Auto"/> <!-- Text Row -->
            </Grid.RowDefinitions>

            <!-- Media Controls (Minimal) -->
            <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,2,0,2">
                <StackPanel.Resources>
                    <Style x:Key="GhostBtn" TargetType="Button">
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="Foreground" Value="#55FFFFFF"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="FontSize" Value="11"/>
                        <Setter Property="FontFamily" Value="Segoe UI Symbol"/>
                        <Setter Property="Padding" Value="4,1"/>
                        <Setter Property="Cursor" Value="Hand"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="Button">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="#CCFFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Foreground" Value="Cyan"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                    <Style x:Key="VolBtn" TargetType="Button" BasedOn="{StaticResource GhostBtn}">
                        <Setter Property="FontSize" Value="9"/>
                        <Setter Property="Foreground" Value="#44FFFFFF"/>
                        <Setter Property="Padding" Value="2,1"/>
                    </Style>
                </StackPanel.Resources>

                <!-- Transport -->
                <Button Style="{StaticResource GhostBtn}" Command="{Binding PreviousTrackCommand}" Content="⏮" FontSize="14"/>
                <Button Style="{StaticResource GhostBtn}" Command="{Binding PlayPauseCommand}" Content="⏯" FontSize="16"/>
                <Button Style="{StaticResource GhostBtn}" Command="{Binding NextTrackCommand}" Content="⏭" FontSize="14"/>
            </StackPanel>

            <!-- EDDIE IMAGE (Above Box) -->
            <Grid Grid.Row="1" Margin="0,0,0,10" Visibility="{Binding IsEddieMode, Converter={StaticResource BoolToVis}}">
                 <!-- Background Glow (Treble-reactive) -->
                 <Ellipse Width="350" Height="350" 
                          HorizontalAlignment="Center" VerticalAlignment="Center"
                          Opacity="{Binding EddieBgGlowIntensity}">
                     <Ellipse.Fill>
                         <RadialGradientBrush>
                             <GradientStop Color="#FF6600FF" Offset="0.0"/>
                             <GradientStop Color="#FF3300AA" Offset="0.4"/>
                             <GradientStop Color="Transparent" Offset="1.0"/>
                         </RadialGradientBrush>
                     </Ellipse.Fill>
                     <Ellipse.Effect>
                         <BlurEffect Radius="{Binding EddieBgGlowRadius}"/>
                     </Ellipse.Effect>
                 </Ellipse>

                 <!-- Main Mascot Image -->
                 <Image Source="Assets/eddie.png" Height="300" Stretch="Uniform"/>
                 
                 <!-- Left Eye Glow -->
                 <Ellipse Width="30" Height="30" Fill="Red" Opacity="{Binding EddieEyeIntensity}" 
                          HorizontalAlignment="Center" VerticalAlignment="Center">
                     <Ellipse.Effect>
                         <BlurEffect Radius="20"/>
                     </Ellipse.Effect>
                     <Ellipse.RenderTransform>
                         <TranslateTransform X="{Binding EddieEyeGap, Converter={StaticResource InvertDoubleConverter}}" Y="{Binding EddieEyeHeight}"/>
                     </Ellipse.RenderTransform>
                 </Ellipse>

                 <!-- Right Eye Glow -->
                 <Ellipse Width="30" Height="30" Fill="Red" Opacity="{Binding EddieEyeIntensity}" 
                          HorizontalAlignment="Center" VerticalAlignment="Center">
                     <Ellipse.Effect>
                         <BlurEffect Radius="20"/>
                     </Ellipse.Effect>
                     <Ellipse.RenderTransform>
                         <TranslateTransform X="{Binding EddieEyeGap}" Y="{Binding EddieEyeHeight}"/>
                     </Ellipse.RenderTransform>
                 </Ellipse>
            </Grid>

            <!-- MAIN VISUALIZER BOX -->
            <ContentControl Grid.Row="2" VerticalAlignment="Bottom" Height="120" Margin="10,0,10,5">
                <ContentControl.Resources>
                    <!-- BARS TEMPLATE (Default) -->
                    <DataTemplate x:Key="BarsTemplate">
                        <ItemsControl ItemsSource="{Binding SpectrumData}" Height="120" VerticalAlignment="Bottom">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <UniformGrid Rows="1"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid VerticalAlignment="Bottom" Height="120" Margin="1,0">
                                        <Rectangle VerticalAlignment="Bottom" RadiusX="1" RadiusY="1">
                                            <Rectangle.Fill>
                                                <Binding Path="DataContext.BarBrush" RelativeSource="{RelativeSource AncestorType=Window}"/>
                                            </Rectangle.Fill>
                                            <Rectangle.LayoutTransform>
                                                <ScaleTransform ScaleY="{Binding Value}"/>
                                            </Rectangle.LayoutTransform>
                                            <Rectangle.Height>120</Rectangle.Height>
                                        </Rectangle>
                                        <Rectangle Height="2" HorizontalAlignment="Stretch" VerticalAlignment="Bottom" Fill="White" Opacity="0.8"
                                                   Visibility="{Binding DataContext.IsPeakHoldEnabled, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource BoolToVis}}">
                                            <Rectangle.RenderTransform>
                                                <TranslateTransform Y="{Binding PeakY}"/>
                                            </Rectangle.RenderTransform>
                                        </Rectangle>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </DataTemplate>

                    <!-- OSCILLOSCOPE TEMPLATE -->
                    <DataTemplate x:Key="OscilloscopeTemplate">
                        <Grid>
                             <Polyline Points="{Binding WaveformPoints}"
                                      Stroke="{Binding BarBrush}"
                                      StrokeThickness="{Binding LineThickness}"
                                      StrokeLineJoin="Round"
                                      VerticalAlignment="Top">
                                 <Polyline.Effect>
                                     <DropShadowEffect Color="{Binding BarBrush.GradientStops[1].Color, FallbackValue=Cyan}" BlurRadius="10" ShadowDepth="0" Opacity="0.8"/>
                                 </Polyline.Effect>
                             </Polyline>
                        </Grid>
                    </DataTemplate>
                </ContentControl.Resources>

                <!-- Style to Switch Templates -->
                <ContentControl.Style>
                    <Style TargetType="ContentControl">
                        <Setter Property="Content" Value="{Binding}"/>
                        <Setter Property="ContentTemplate" Value="{StaticResource BarsTemplate}"/> <!-- Default -->
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsOscilloscopeMode}" Value="True">
                                <Setter Property="ContentTemplate" Value="{StaticResource OscilloscopeTemplate}"/>
                            </DataTrigger>
                            <!-- Eddie Mode handled outside ContentControl -->
                        </Style.Triggers>
                    </Style>
                </ContentControl.Style>
            </ContentControl>

            <!-- Now Playing Marquee -->
            <!-- Reduced grid height, closer to bottom -->
            <Grid Grid.Row="3" ClipToBounds="True" Height="20" VerticalAlignment="Bottom" Margin="0,0,0,0" Visibility="{Binding IsScrollingTextVisible, Converter={StaticResource BoolToVis}}">
                <Canvas>
                    <!-- Modern Font Style: Segoe UI, SemiBold, Uppercase, Spaced -->
                    <TextBlock x:Name="ScrollingText" 
                               Text="{Binding CurrentTrackName}"
                               Foreground="{Binding CurrentBrush}"
                               FontFamily="{Binding CurrentFontFamily}"
                               FontSize="14">

                        <TextBlock.CacheMode>
                            <BitmapCache EnableClearType="False" RenderAtScale="1" SnapsToDevicePixels="True"/>
                        </TextBlock.CacheMode>
                        <TextBlock.Effect>
                            <DropShadowEffect Color="{Binding CurrentShadowColor}"
                                              BlurRadius="{Binding CurrentBlur}"
                                              ShadowDepth="{Binding CurrentShadowDepth}"
                                              Opacity="0.9"/>
                        </TextBlock.Effect>

                        <TextBlock.RenderTransform>
                            <TranslateTransform x:Name="MarqueeTransform" X="400"/>
                        </TextBlock.RenderTransform>
                    </TextBlock>
                </Canvas>
            </Grid>
        </Grid>
    </Border>

    <Border Background="#B3000000" CornerRadius="12" BorderBrush="#33FFFFFF" BorderThickness="1" Margin="5,0,5,5"
            Visibility="{Binding IsAlbumArtVisible, Converter={StaticResource BoolToVis}}">
        <Image Source="{Binding AlbumArtSource}" Stretch="Uniform" Margin="0"
               RenderOptions.BitmapScalingMode="Fant">
            <Image.CacheMode>
                <BitmapCache RenderAtScale="2" SnapsToDevicePixels="True"/>
            </Image.CacheMode>
        </Image>
    </Border>
    </StackPanel>

</Window>
